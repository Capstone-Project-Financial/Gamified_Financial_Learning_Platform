# Server Configuration
NODE_ENV=development
PORT=5000

# Database
MONGODB_URI=your-mongodb-connection-string

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Client URL (Frontend URL)
# In production, set this to your deployed frontend URL (e.g. https://your-app.netlify.app)
CLIENT_URL=http://localhost:5173

# Email Service Configuration (Brevo / Sendinblue)
# Get your API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key

# Legacy SMTP Email Configuration (Optional — used only if BREVO_API_KEY is not set)
# For Gmail: Use App Password (https://myaccount.google.com/apppasswords)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password-16-chars
EMAIL_FROM=FinLearn <your-email@gmail.com>

# Alternative Email Services:
# SendGrid:
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_USER=apikey
# EMAIL_PASSWORD=your-sendgrid-api-key

# Mailgun:
# EMAIL_HOST=smtp.mailgun.org
# EMAIL_USER=your-mailgun-smtp-username
# EMAIL_PASSWORD=your-mailgun-smtp-password

# Google OAuth 2.0 (Optional - enables "Sign in with Google")
# Get credentials from: https://console.cloud.google.com/apis/credentials
# IMPORTANT: In production, GOOGLE_CALLBACK_URL must match an Authorized redirect URI
# registered in your Google Cloud Console OAuth 2.0 client settings.
# Example production value: https://your-api.onrender.com/api/auth/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
